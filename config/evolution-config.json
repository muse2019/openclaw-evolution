{
  "evolutionEnabled": true,
  "triggers": {
    "error": {
      "enabled": true,
      "threshold": 3,
      "cooldownMinutes": 30
    },
    "timer": {
      "enabled": true,
      "intervalHours": 24
    },
    "manual": {
      "enabled": true
    }
  },
  "limits": {
    "auto": { "perHour": 10, "perDay": 50 },
    "ask": { "perHour": 5, "perDay": 20 },
    "forbid": { "perHour": 20, "perDay": 100 }
  },
  "paths": {
    "allowlist": [
      "**/.openclaw/workspace/skills/**",
      "**/.openclaw/config/preferences.json",
      "**/.openclaw/memory/**"
    ],
    "blocklist": [
      "**/.openclaw/auth/**",
      "**/.openclaw/secrets/**",
      "**/.env",
      "**/.env.*",
      "**/credentials.json",
      "**/api-keys.json",
      "**/*.pem",
      "**/*.key"
    ]
  },
  "autoRollback": {
    "enabled": true,
    "errorIncreaseThreshold": 50
  }
}
